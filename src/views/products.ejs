<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Danh sách sản phẩm</h1>
        <p class="text-sm text-slate-500 mt-1">Quản lý kho hàng và giá bán của bạn</p>
    </div>
    
    <a href="/admin/products/create" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-semibold transition-all flex items-center gap-2 shadow-lg shadow-indigo-200 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Thêm sản phẩm mới
    </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/80 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
                    <th class="px-8 py-4 font-bold">Hình ảnh</th>
                    <th class="px-8 py-4 font-bold">Tên sản phẩm</th>
                    <th class="px-8 py-4 font-bold text-right">Giá bán</th>
                    <th class="px-8 py-4 font-bold text-center">Tồn kho</th>
                    <th class="px-8 py-4 font-bold text-right">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(p => { %>
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-8 py-4">
                                <div class="w-12 h-12 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400 overflow-hidden border border-slate-200">
                                    <% if (p.images && p.images.length > 0 && p.images[0]) { %>
                                        <img src="<%= p.images[0] %>" alt="<%= p.name %>" class="w-full h-full object-cover">
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                                        </svg>
                                    <% } %>
                                </div>
                            </td>
                            <td class="px-8 py-4">
                                <div class="font-semibold text-slate-700 truncate max-w-[200px]"><%= p.name %></div>
                                <div class="text-[10px] text-slate-400 mt-1 uppercase">Mã: <%= p._id.toString().substring(18) %></div>
                            </td>
                            <td class="px-8 py-4 text-right">
                                <div class="flex flex-col items-end">
                                    <span class="text-indigo-600 font-bold text-lg"><%= Number(p.price).toLocaleString('vi-VN') %></span>
                                    <span class="text-[10px] text-indigo-400 font-medium uppercase">VNĐ</span>
                                </div>
                            </td>
                            <td class="px-8 py-4 text-center">
                                <% if (p.stock > 10) { %>
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-600">
                                        <span class="w-1.5 h-1.5 rounded-full mr-1.5 bg-emerald-500 animate-pulse"></span>
                                        <%= p.stock %> trong kho
                                    </span>
                                <% } else if (p.stock > 0) { %>
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-amber-50 text-amber-600">
                                        <span class="w-1.5 h-1.5 rounded-full mr-1.5 bg-amber-500"></span>
                                        Chỉ còn <%= p.stock %>
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-rose-50 text-rose-600">
                                        <span class="w-1.5 h-1.5 rounded-full mr-1.5 bg-rose-500"></span>
                                        Hết hàng
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-8 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a href="/admin/products/edit/<%= p._id %>" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" title="Sửa sản phẩm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <button onclick="confirmDelete('<%= p._id %>')" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all" title="Xóa sản phẩm">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-8 py-24 text-center">
                            <div class="flex flex-col items-center gap-4">
                                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-slate-500 font-bold text-lg">Kho hàng đang trống</p>
                                    <p class="text-slate-400 text-sm">Bắt đầu thêm sản phẩm để quản lý kinh doanh ngay hôm nay.</p>
                                </div>
                                <a href="/admin/products/create" class="text-indigo-600 font-semibold hover:underline">Thêm sản phẩm đầu tiên &rarr;</a>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    function confirmDelete(id) {
        if(confirm('Cảnh báo: Bạn có chắc chắn muốn xóa sản phẩm này? Thao tác này sẽ xóa vĩnh viễn dữ liệu khỏi hệ thống.')) {
            // Chuyển hướng tới route xóa
            window.location.href = `/admin/products/delete/${id}`;
        }
    }
</script>