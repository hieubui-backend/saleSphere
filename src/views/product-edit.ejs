<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <a href="/admin/products" class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Quay lại danh sách
        </a>
        <h1 class="text-3xl font-extrabold text-slate-900">Chỉnh sửa sản phẩm</h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 flex items-center gap-3 rounded-r-xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium"><%= error %></span>
        </div>
    <% } %>

    <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Tên sản phẩm *</label>
                        <input type="text" name="name" value="<%= product.name %>" required 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Danh mục *</label>
                        <input type="text" name="category" value="<%= product.category %>" required placeholder="Ví dụ: Đồ điện tử, Thời trang..."
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Giá bán (đ) *</label>
                            <input type="number" name="price" value="<%= product.price %>" required 
                                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Tồn kho *</label>
                            <input type="number" name="stock" value="<%= product.stock %>" required 
                                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Mô tả sản phẩm</label>
                        <textarea name="description" rows="3" 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none resize-none"><%= product.description %></textarea>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Hình ảnh hiện tại</label>
                        <div class="grid grid-cols-3 gap-2 p-4 border border-dashed border-slate-200 rounded-xl bg-slate-50">
                            <% if (product.images && product.images.length > 0) { %>
                                <% product.images.forEach(img => { %>
                                    <div class="relative aspect-square rounded-lg overflow-hidden border border-white shadow-sm">
                                        <img src="<%= img %>" class="w-full h-full object-cover">
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="col-span-3 text-xs text-slate-400 text-center py-4">Chưa có hình ảnh</p>
                            <% } %>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Thay đổi ảnh mới</label>
                        <input type="file" name="images" multiple accept="image/*"
                            class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
                    </div>
                </div>

            </div>
        </div>

        <div class="flex items-center justify-end gap-4">
            <a href="/admin/products" class="px-6 py-3 text-slate-600 font-medium hover:text-slate-800 transition-colors">Hủy bỏ</a>
            <button type="submit" class="px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-lg transition-all transform active:scale-95">
                Cập nhật sản phẩm
            </button>
        </div>
    </form>
</div>