<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid py-4 px-lg-5" style="font-family: 'Plus Jakarta Sans', sans-serif;">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a href="/admin/orders" class="btn btn-back shadow-sm">
            <i class="fas fa-chevron-left me-2"></i>Quay lại danh sách
        </a>
        <div class="text-end">
            <span class="text-muted small">Cửa hàng:</span>
            <span class="fw-700 text-primary ms-1"><%= order.tenantId?.shopName || order.tenantId?.name || 'Hệ thống' %></span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <% if (order.dispute && order.dispute.isDisputed) { %>
                <div class="card border-0 shadow-sm mb-4 card-dispute">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <div class="d-flex align-items-center justify-content-between">
                            <h5 class="mb-0 text-danger fw-700">
                                <span class="pulse-red"></span>
                                <i class="fas fa-shield-alt me-2"></i>TRUNG TÂM KHIẾU NẠI
                            </h5>
                            <span class="badge bg-soft-danger text-danger rounded-pill px-3">
                                <%= order.dispute.status === 'pending' ? 'Đang chờ xử lý' : (order.dispute.status === 'accepted' ? 'Đã chấp nhận' : 'Đã từ chối') %>
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="dispute-box rounded-4 p-4 mb-4">
                            <div class="row">
                                <div class="col-md-7 border-end-md">
                                    <h6 class="text-muted small fw-bold text-uppercase ls-1 mb-3">Lý do từ khách hàng</h6>
                                    <div class="reason-tag mb-3"><%= order.dispute.reason %></div>
                                    <p class="text-secondary bg-white p-3 rounded-3 border border-light-subtle shadow-sm italic mb-3">
                                        "<%= order.dispute.description || 'Không có mô tả chi tiết.' %>"
                                    </p>
                                    <div class="small text-muted">
                                        <i class="far fa-calendar-alt me-1"></i> Gửi ngày: <%= new Date(order.dispute.requestedAt).toLocaleString('vi-VN') %>
                                    </div>
                                </div>
                                <div class="col-md-5 mt-4 mt-md-0 ps-md-4 text-center">
                                    <h6 class="text-muted small fw-bold text-uppercase ls-1 mb-3">Bằng chứng hình ảnh</h6>
                                    <% if (order.dispute.images && order.dispute.images.length > 0) { %>
                                        <div class="evidence-grid">
                                            <% order.dispute.images.forEach(img => { %>
                                                <a href="<%= img %>" target="_blank" class="evidence-item shadow-sm border">
                                                    <img src="<%= img %>" alt="Evidence" onerror="this.src='https://placehold.co/100x100?text=Error'">
                                                    <div class="overlay"><i class="fas fa-eye"></i></div>
                                                </a>
                                            <% }) %>
                                        </div>
                                    <% } else { %>
                                        <div class="no-image-placeholder py-4">
                                            <i class="fas fa-image-slash opacity-25 fa-2x"></i>
                                            <p class="small text-muted mt-2">Không có ảnh</p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <% if (order.dispute.status === 'pending') { %>
                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                            <button onclick="handleResolveDispute('<%= order._id %>', 'reject')" class="btn btn-outline-secondary btn-action">
                                <i class="fas fa-ban me-2"></i>Bác bỏ khiếu nại
                            </button>
                            <button onclick="handleResolveDispute('<%= order._id %>', 'accept')" class="btn btn-danger btn-action shadow-danger">
                                <i class="fas fa-check-double me-2"></i>Chấp nhận hoàn tiền
                            </button>
                        </div>
                        <% } %>
                    </div>
                </div>
            <% } %>

            <div class="card border-0 shadow-sm border-radius-20 overflow-hidden">
                <div class="card-header bg-white py-4 px-4 border-0">
                    <h5 class="mb-0 fw-700 text-dark"><i class="fas fa-box-open me-2 text-primary opacity-75"></i>Chi tiết kiện hàng</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-faded-light text-muted small text-uppercase fw-700">
                            <tr>
                                <th class="ps-4 py-3">Sản phẩm</th>
                                <th class="py-3">Đơn giá</th>
                                <th class="py-3">Số lượng</th>
                                <th class="text-end pe-4 py-3">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.items.forEach(item => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="product-thumb">
                                                <img src="<%= (item.productId?.images && item.productId.images[0]) ? item.productId.images[0] : (item.image || 'https://placehold.co/100x100') %>" 
                                                     alt="Product" onerror="this.src='https://placehold.co/100x100'">
                                            </div>
                                            <div class="ms-3">
                                                <div class="fw-700 text-dark mb-0"><%= item.name || item.productId?.name %></div>
                                                <code class="text-muted x-small">ID: <%= item.productId?._id?.toString().slice(-6).toUpperCase() || 'N/A' %></code>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="fw-600 text-secondary"><%= item.price.toLocaleString() %>đ</td>
                                    <td>
                                        <span class="qty-pill">x<%= item.quantity %></span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <span class="fw-700 text-dark"><%= (item.price * item.quantity).toLocaleString() %>đ</span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white p-4 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted fw-bold">TỔNG CỘNG THANH TOÁN</span>
                        <h3 class="mb-0 text-primary fw-800"><%= order.totalAmount.toLocaleString() %>đ</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4 border-radius-20">
                <div class="card-body p-4">
                    <h6 class="section-title mb-4">THÔNG TIN GIAO HÀNG</h6>
                    <div class="shipping-info">
                        <div class="info-item mb-3">
                            <div class="icon-box bg-soft-primary"><i class="fas fa-user"></i></div>
                            <div class="ms-3">
                                <small class="text-muted d-block">Người nhận</small>
                                <p class="mb-0 fw-700"><%= order.shippingAddress?.fullName || order.userId?.name || 'Khách vãng lai' %></p>
                            </div>
                        </div>
                        <div class="info-item mb-3">
                            <div class="icon-box bg-soft-success"><i class="fas fa-phone-alt"></i></div>
                            <div class="ms-3">
                                <small class="text-muted d-block">Số điện thoại</small>
                                <p class="mb-0 fw-700 text-primary"><%= order.shippingAddress?.phone || order.userId?.phone || 'Chưa cập nhật' %></p>
                            </div>
                        </div>
                        <div class="info-item mb-3">
                            <div class="icon-box bg-soft-info"><i class="fas fa-map-marked-alt"></i></div>
                            <div class="ms-3">
                                <small class="text-muted d-block">Địa chỉ nhận</small>
                                <p class="small mb-0 fw-600 text-dark">
                                    <% if (order.shippingAddress?.address) { %>
                                        <%= order.shippingAddress.address %>,<br>
                                        <%= order.shippingAddress.ward %>, <%= order.shippingAddress.district %>, <%= order.shippingAddress.city %>
                                    <% } else { %>
                                        N/A
                                    <% } %>
                                </p>
                            </div>
                        </div>
                        <% if (order.trackingNumber) { %>
                        <div class="info-item mt-3 pt-3 border-top">
                            <div class="icon-box bg-light"><i class="fas fa-truck text-secondary"></i></div>
                            <div class="ms-3">
                                <small class="text-muted d-block">Mã vận đơn (<%= order.shippingPartner %>)</small>
                                <p class="mb-0 fw-700 text-dark"><%= order.trackingNumber %></p>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm border-radius-20">
                <div class="card-body p-4">
                    <h6 class="section-title mb-4 text-center">TRẠNG THÁI ĐƠN HÀNG</h6>
                    <% 
                        let colorMap = {
                            'pending': {bg: '#fff7ed', text: '#c2410c', label: 'Chờ xác nhận'},
                            'processing': {bg: '#eff6ff', text: '#1d4ed8', label: 'Đang xử lý'},
                            'shipping': {bg: '#f0fdf4', text: '#15803d', label: 'Đang giao hàng'},
                            'completed': {bg: '#f0f9ff', text: '#0369a1', label: 'Hoàn thành'},
                            'cancelled': {bg: '#fef2f2', text: '#b91c1c', label: 'Đã hủy'},
                            'failed': {bg: '#fff1f2', text: '#e11d48', label: 'Giao hàng lỗi'},
                            'returned': {bg: '#f5f3ff', text: '#6d28d9', label: 'Đã hoàn hàng'}
                        };
                        let current = colorMap[order.status] || colorMap['pending'];
                    %>
                    <div class="status-main rounded-pill mb-4" style="background: <%= current.bg %>; color: <%= current.text %>;">
                        <i class="fas fa-circle-notch fa-spin me-2 small"></i><%= current.label.toUpperCase() %>
                    </div>
                    
                    <div class="order-meta border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Mã tra cứu:</span>
                            <span class="fw-bold">#<%= order._id.toString().slice(-8).toUpperCase() %></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Ngày đặt:</span>
                            <span class="small fw-600"><%= new Date(order.createdAt).toLocaleString('vi-VN') %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-color: #4361ee;
        --secondary-color: #8392a5;
        --danger-soft: #fff1f2;
    }

    body { background-color: #f0f2f5; }
    .fw-700 { font-weight: 700; }
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 0.5px; }
    .border-radius-20 { border-radius: 20px; }

    /* Buttons */
    .btn-back {
        background: white;
        border-radius: 50px;
        padding: 8px 24px;
        font-weight: 600;
        color: var(--secondary-color);
        transition: 0.3s;
        border: 1px solid #e0e0e0;
        text-decoration: none;
        display: inline-block;
    }
    .btn-back:hover { background: #f8f9fa; color: var(--primary-color); transform: translateX(-5px); }

    .btn-action { border-radius: 12px; padding: 12px 24px; font-weight: 700; transition: 0.3s; }
    .shadow-danger { box-shadow: 0 10px 20px -5px rgba(220, 53, 69, 0.4); }

    /* Dispute Card */
    .card-dispute { border-left: 6px solid #dc3545 !important; background: #fffbff; }
    .dispute-box { background: #fcf8f8; border: 1px solid #fceaea; }
    .reason-tag { display: inline-block; padding: 6px 16px; background: #dc3545; color: white; border-radius: 8px; font-weight: 700; font-size: 0.9rem; }
    
    /* Evidence Grid */
    .evidence-grid { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
    .evidence-item { position: relative; width: 100px; height: 100px; border-radius: 12px; overflow: hidden; }
    .evidence-item img { width: 100%; height: 100%; object-fit: cover; }
    .evidence-item .overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; opacity: 0; color: white; transition: 0.3s; }
    .evidence-item:hover .overlay { opacity: 1; }

    /* Products */
    .product-thumb { width: 64px; height: 64px; border-radius: 12px; overflow: hidden; border: 1px solid #eee; background: #fff; }
    .product-thumb img { width: 100%; height: 100%; object-fit: contain; }
    .qty-pill { padding: 4px 12px; background: #f1f5f9; color: #475569; border-radius: 50px; font-weight: 700; font-size: 0.85rem; }

    /* Info Column */
    .section-title { font-size: 0.75rem; color: #94a3b8; letter-spacing: 1.5px; font-weight: 800; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px; }
    .info-item { display: flex; align-items: flex-start; }
    .icon-box { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
    .bg-soft-primary { background: #eef2ff; color: #4361ee; }
    .bg-soft-success { background: #f0fdf4; color: #22c55e; }
    .bg-soft-info { background: #f0f9ff; color: #0ea5e9; }
    .bg-soft-danger { background: #fef2f2; color: #ef4444; }

    .status-main { padding: 16px; text-align: center; font-weight: 800; font-size: 1.1rem; letter-spacing: 1px; }

    /* Animation pulse */
    .pulse-red {
        display: inline-block; width: 10px; height: 10px; background: #dc3545; border-radius: 50%; margin-right: 10px;
        box-shadow: 0 0 0 rgba(220, 53, 69, 0.4); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); } 70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); } 100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); } }

    @media (min-width: 768px) { .border-end-md { border-right: 1px solid #f1f5f9; } }
</style>

<script>
async function handleResolveDispute(orderId, action) {
    const isAccept = action === 'accept';
    
    const { value: shopResponse } = await Swal.fire({
        title: isAccept ? 'Chấp nhận hoàn tiền?' : 'Bác bỏ khiếu nại?',
        text: isAccept ? 'Hành động này sẽ hoàn tiền cho khách và cộng lại tồn kho.' : 'Vui lòng nhập lý do từ chối khiếu nại.',
        input: 'textarea',
        inputPlaceholder: 'Nhập phản hồi của bạn tại đây...',
        icon: isAccept ? 'warning' : 'question',
        showCancelButton: true,
        confirmButtonColor: isAccept ? '#dc3545' : '#6e7881',
        cancelButtonColor: '#f1f5f9',
        cancelButtonText: '<span style="color: #475569">Hủy bỏ</span>',
        confirmButtonText: isAccept ? 'Xác nhận Hoàn tiền' : 'Gửi phản hồi Từ chối',
        inputValidator: (value) => {
            if (!value && !isAccept) return 'Bạn phải nhập lý do từ chối!';
        }
    });

    if (shopResponse === undefined) return; 

    Swal.fire({ title: 'Đang xử lý...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

    try {
        const response = await fetch(`/admin/orders/${orderId}/resolve-dispute`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action, shopResponse })
        });

        const result = await response.json();

        if (result.success) {
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: result.message,
                timer: 2000,
                showConfirmButton: false
            }).then(() => window.location.reload());
        } else {
            Swal.fire('Lỗi!', result.message || 'Không thể xử lý.', 'error');
        }
    } catch (error) {
        Swal.fire('Lỗi kết nối!', 'Không thể gửi yêu cầu đến máy chủ.', 'error');
    }
}
</script>