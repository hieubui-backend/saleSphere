<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/socket.io/socket.io.js"></script>

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Quản lý đơn hàng</h1>
        <p class="text-sm text-slate-500 mt-1">Xử lý vận đơn, in hóa đơn và phê duyệt tranh chấp hệ thống</p>
    </div>
    <div class="flex gap-3">
        <button onclick="window.print()" class="bg-white border border-slate-200 text-slate-600 px-4 py-2 rounded-lg font-medium hover:bg-slate-50 transition-all flex items-center gap-2 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            In báo cáo nhanh
        </button>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="orderTable">
            <thead>
                <tr class="bg-slate-50/80 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
                    <th class="px-8 py-4 font-bold">Mã đơn hàng</th>
                    <th class="px-8 py-4 font-bold">Khách hàng</th>
                    <th class="px-8 py-4 font-bold text-center">Ngày đặt</th>
                    <th class="px-8 py-4 font-bold text-right">Tổng tiền</th>
                    <th class="px-8 py-4 font-bold text-center">Trạng thái</th>
                    <th class="px-8 py-4 font-bold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr class="hover:bg-slate-50/50 transition-colors group" id="row-<%= order._id %>">
                            <td class="px-8 py-4 font-mono text-xs font-bold text-indigo-600">
                                #<%= order._id.toString().substring(18).toUpperCase() %>
                            </td>
                            <td class="px-8 py-4">
                                <div class="text-slate-700 font-medium">
                                    <%= (order.userId && order.userId.name) ? order.userId.name : (order.customerName || 'Khách vãng lai') %>
                                </div>
                                <div class="text-xs text-slate-400">
                                    <%= order.phone || (order.userId && order.userId.phone) || 'Không có SĐT' %>
                                </div>
                            </td>
                            <td class="px-8 py-4 text-slate-500 text-sm text-center">
                                <%= new Date(order.createdAt).toLocaleDateString('vi-VN') %>
                            </td>
                            <td class="px-8 py-4 text-right font-bold text-slate-900">
                                <%= order.totalAmount.toLocaleString() %>₫
                            </td>
                            <td class="px-8 py-4 text-center">
                                <% 
                                    const statusStyles = {
                                        'pending':           { class: 'bg-amber-50 text-amber-600', text: 'Chờ Shop duyệt' },
                                        'dispute_escalated': { class: 'bg-rose-100 text-rose-700 ring-1 ring-rose-200 animate-pulse', text: 'Sàn cần duyệt' },
                                        'processing':        { class: 'bg-purple-50 text-purple-600', text: 'Đóng gói' },
                                        'shipping':          { class: 'bg-sky-50 text-sky-600', text: 'Đang giao' },
                                        'completed':         { class: 'bg-emerald-50 text-emerald-600', text: 'Đã giao' },
                                        'cancelled':         { class: 'bg-slate-100 text-slate-500', text: 'Đã hủy' },
                                        'returned':          { class: 'bg-orange-100 text-orange-700 font-black', text: 'ĐÃ HOÀN TRẢ' },
                                        'failed':            { class: 'bg-red-50 text-red-700', text: 'Giao lỗi' }
                                    };
                                    
                                    let currentStyle = statusStyles[order.status] || statusStyles['pending'];
                                    
                                    if (order.dispute && order.dispute.isDisputed && order.dispute.status === 'pending') {
                                        currentStyle = { class: 'bg-orange-50 text-orange-600 ring-1 ring-orange-200', text: 'Khiếu nại mới' };
                                    }
                                %>
                                <span class="status-badge px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= currentStyle.class %>">
                                    <%= currentStyle.text %>
                                </span>
                            </td>
                            <td class="px-8 py-4 text-right">
                                <div class="flex justify-end items-center gap-2">
                                    <% if (order.status === 'pending') { %>
                                        <button onclick="handleStatusUpdate('<%= order._id %>', 'process')" class="bg-indigo-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-indigo-700 shadow-sm transition-all">Xác nhận</button>
                                        <button onclick="handleCancelOrder('<%= order._id %>')" class="text-rose-600 text-xs font-bold px-2 hover:underline">Hủy</button>

                                    <% } else if (order.status === 'dispute_escalated') { %>
                                        <% if (user && user.role === 'super-admin') { %>
                                            <button onclick="handleResolveDispute('<%= order._id %>', 'accept')" class="bg-rose-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-rose-700 shadow-sm animate-pulse">Sàn Duyệt Hoàn</button>
                                        <% } else { %>
                                            <span class="text-[10px] text-slate-400 italic font-medium">Đang chờ Sàn phân xử</span>
                                        <% } %>

                                    <% } else if (order.dispute && order.dispute.isDisputed && order.dispute.status === 'pending') { %>
                                        <button onclick="handleResolveDispute('<%= order._id %>', 'accept')" class="bg-orange-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-orange-600">Chấp nhận hoàn</button>
                                        <button onclick="handleResolveDispute('<%= order._id %>', 'reject')" class="bg-slate-400 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-slate-500">Từ chối</button>

                                    <% } else if (order.status === 'processing') { %>
                                        <button onclick='printInvoice(<%- JSON.stringify(order) %>)' class="border border-slate-200 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-slate-50">In đơn</button>
                                        <button onclick="handleStatusUpdate('<%= order._id %>', 'ship')" class="bg-purple-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-purple-700">Giao vận</button>
                                    <% } %>
                                    
                                    <a href="/admin/orders/<%= order._id %>" class="text-slate-400 hover:text-indigo-600 p-1" title="Chi tiết">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="6" class="px-8 py-12 text-center text-slate-400 italic">Chưa có dữ liệu đơn hàng.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<div id="invoice-wrapper" style="display: none; position: absolute; left: -9999px;">
    <div id="invoice-template" style="width: 210mm; padding: 15mm; background: white; font-family: 'Segoe UI', sans-serif;">
        <div style="display: flex; justify-content: space-between; border-bottom: 4px solid #1e293b; padding-bottom: 15px;">
            <div>
                <h1 id="inv-shop-name" style="margin: 0; font-size: 28px; color: #4f46e5; font-weight: 800;">SALESPHERE</h1>
                <p style="margin: 5px 0 0 0; font-size: 12px; color: #64748b;">Hệ thống ERP quản trị doanh nghiệp</p>
            </div>
            <div id="qrcode"></div>
        </div>
        <div style="text-align: center; margin: 30px 0;">
            <h2 style="margin: 0; font-size: 22px; text-transform: uppercase; font-weight: 700;">Hóa đơn bán hàng</h2>
            <p style="margin: 5px 0; font-weight: bold; color: #6366f1;" id="inv-id-display"></p>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; font-size: 13px;">
            <div style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">
                <p style="margin: 0 0 5px 0; font-weight: bold; color: #1e293b;">KHÁCH HÀNG:</p>
                <p style="margin: 2px 0; font-weight: 600;" id="inv-customer"></p>
                <p style="margin: 2px 0;" id="inv-phone"></p>
            </div>
            <div style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">
                <p style="margin: 0 0 5px 0; font-weight: bold; color: #1e293b;">THÔNG TIN:</p>
                <p style="margin: 2px 0;">Ngày đặt: <span id="inv-date"></span></p>
                <p style="margin: 2px 0;">Trạng thái: Đã xác nhận</p>
            </div>
        </div>
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
            <thead>
                <tr style="background: #1e293b; color: white;">
                    <th style="padding: 12px; text-align: left;">Sản phẩm</th>
                    <th style="padding: 12px; text-align: center;">SL</th>
                    <th style="padding: 12px; text-align: right;">Thành tiền</th>
                </tr>
            </thead>
            <tbody id="inv-items-body"></tbody>
            <tfoot>
                <tr>
                    <td colspan="2" style="text-align: right; padding: 25px 10px; font-weight: bold;">TỔNG THANH TOÁN:</td>
                    <td style="padding: 25px 10px; text-align: right; font-weight: 800; font-size: 20px; color: #ef4444;" id="inv-total-amount"></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
    const socket = typeof io !== 'undefined' ? io() : null;

    // Xử lý giải quyết khiếu nại (Dispute)
    async function handleResolveDispute(orderId, action) {
        const isSuperAdmin = '<%= user.role %>' === 'super-admin';
        const config = {
            accept: { 
                title: isSuperAdmin ? 'Sàn duyệt hoàn tiền?' : 'Duyệt hoàn tiền?', 
                text: 'Hệ thống sẽ hoàn tiền cho khách và cập nhật tồn kho.', 
                confirmBtn: 'Xác nhận hoàn', 
                color: '#ea580c' 
            },
            reject: { 
                title: 'Từ chối khiếu nại?', 
                text: 'Đơn hàng sẽ chuyển lên trạng thái "Tranh chấp" để Sàn xử lý.', 
                confirmBtn: 'Từ chối (Gửi lên Sàn)', 
                color: '#64748b' 
            }
        };

        const { isConfirmed } = await Swal.fire({
            title: config[action].title,
            text: config[action].text,
            icon: action === 'accept' ? 'warning' : 'question',
            showCancelButton: true,
            confirmButtonColor: config[action].color,
            confirmButtonText: config[action].confirmBtn,
            cancelButtonText: 'Đóng'
        });

        if (isConfirmed) {
            showLoading();
            try {
                const res = await fetch(`/admin/orders/${orderId}/resolve-dispute`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action, shopResponse: 'Thao tác phê duyệt từ hệ thống.' })
                });
                handleResponse(await res.json());
            } catch (err) { handleNetworkError(); }
        }
    }

    // Cập nhật trạng thái đơn hàng (Xác nhận, Giao vận)
    async function handleStatusUpdate(orderId, action) {
        showLoading();
        try {
            const res = await fetch(`/admin/orders/${orderId}/${action}`, { method: 'POST' });
            handleResponse(await res.json());
        } catch (err) { handleNetworkError(); }
    }

    // Hủy đơn hàng
    async function handleCancelOrder(orderId) {
        const { isConfirmed } = await Swal.fire({
            title: 'Hủy đơn hàng?',
            text: 'Tồn kho sẽ được hoàn trả lại hệ thống.',
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'Xác nhận hủy'
        });
        if (isConfirmed) {
            showLoading();
            try {
                const res = await fetch(`/admin/orders/${orderId}/cancel`, { method: 'POST' });
                handleResponse(await res.json());
            } catch (err) { handleNetworkError(); }
        }
    }

    // Hàm in hóa đơn PDF
    function printInvoice(order) {
        const shortId = order._id.toString().substring(18).toUpperCase();
        
        // Lấy tên shop từ tenantId nếu có, ngược lại dùng mặc định
        const shopName = (order.tenantId && order.tenantId.shopName) ? order.tenantId.shopName : 'SALESPHERE';
        const customerName = (order.userId && order.userId.name) ? order.userId.name : (order.customerName || 'Khách lẻ');
        const customerPhone = order.phone || (order.userId && order.userId.phone) || 'N/A';

        document.getElementById('inv-shop-name').innerText = shopName.toUpperCase();
        document.getElementById('inv-id-display').innerText = `#INV-${shortId}`;
        document.getElementById('inv-customer').innerText = customerName;
        document.getElementById('inv-phone').innerText = `SĐT: ${customerPhone}`;
        document.getElementById('inv-date').innerText = new Date(order.createdAt).toLocaleString('vi-VN');
        document.getElementById('inv-total-amount').innerText = order.totalAmount.toLocaleString() + ' ₫';
        
        const rows = order.items.map(item => `
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 12px;">${item.name}</td>
                <td style="padding: 12px; text-align: center;">${item.quantity}</td>
                <td style="padding: 12px; text-align: right; font-weight: 600;">${(item.price * item.quantity).toLocaleString()}</td>
            </tr>`).join('');
        
        document.getElementById('inv-items-body').innerHTML = rows;
        const qrBox = document.getElementById("qrcode");
        qrBox.innerHTML = "";
        new QRCode(qrBox, { text: order._id, width: 60, height: 60 });

        const wrapper = document.getElementById('invoice-wrapper');
        wrapper.style.display = 'block';
        
        html2pdf().from(document.getElementById('invoice-template')).set({
            margin: 0, filename: `Invoice_${shortId}.pdf`,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 3 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        }).save().then(() => { wrapper.style.display = 'none'; });
    }

    // Tiện ích thông báo
    function showLoading() { 
        Swal.fire({ title: 'Đang xử lý...', allowOutsideClick: false, didOpen: () => Swal.showLoading() }); 
    }
    
    function handleResponse(data) {
        if (data.success) {
            Swal.fire({ icon: 'success', title: 'Thành công', text: data.message, timer: 1500, showConfirmButton: false })
            .then(() => { window.location.reload(); });
        } else { 
            Swal.fire('Lỗi', data.message, 'error'); 
        }
    }
    
    function handleNetworkError() { 
        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ', 'error'); 
    }

    // Lắng nghe cập nhật thời gian thực
    if (socket) {
        socket.on('orderUpdate', () => {
            Swal.fire({ toast: true, position: 'top-end', icon: 'info', title: 'Dữ liệu vừa được cập nhật', showConfirmButton: false, timer: 2000 });
            setTimeout(() => location.reload(), 2200);
        });
    }
</script>