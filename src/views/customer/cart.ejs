<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>Giỏ hàng - SaleSphere</title>
    <style>
        :root { --primary-orange: #e44d26; }
        .cart-item-img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; background: #f8f9fa; }
        .text-orange { color: var(--primary-orange); }
        .btn-checkout { background: #28a745; border: none; border-radius: 10px; padding: 12px; font-weight: bold; transition: 0.3s; color: white; }
        .btn-checkout:hover { background: #218838; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(40,167,69,0.3); color: white; }
        .btn-checkout:disabled { background: #6c757d; transform: none; box-shadow: none; }
        .quantity-input { width: 45px; border: none; text-align: center; font-weight: bold; background: transparent; pointer-events: none; }
        .quantity-control { border: 1px solid #ddd; border-radius: 5px; display: inline-flex; align-items: center; background: white; }
        .quantity-control button { border: none; background: none; padding: 5px 12px; font-weight: bold; }
        .quantity-control button:hover { color: var(--primary-orange); }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5 shadow-sm">
        <div class="container">
            <a class="navbar-brand font-weight-bold" href="/customer/home">
                <i class="fas fa-shopping-bag mr-2 text-warning"></i>SaleSphere
            </a>
            <div class="ml-auto text-white">
                <i class="fas fa-user-circle mr-1"></i> 
                <strong><%= (typeof customer !== 'undefined' && customer) ? customer.name : 'Khách hàng' %></strong>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        <h2 class="mb-4 font-weight-bold text-dark"><i class="fas fa-shopping-cart mr-2 text-primary"></i>Giỏ hàng của bạn</h2>
        
        <% if (cart && cart.items && cart.items.length > 0) { %>
            <div class="row">
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm border-0 rounded-lg">
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                <% cart.items.forEach(item => { %>
                                    <% 
                                        let displayImg = '/images/no-image.png';
                                        if (item.productId) {
                                            if (item.productId.image) displayImg = item.productId.image;
                                            else if (item.productId.images && item.productId.images.length > 0) displayImg = item.productId.images[0];
                                        }
                                    %>
                                    <li class="list-group-item p-4">
                                        <div class="row align-items-center">
                                            <div class="col-md-2 col-3 text-center">
                                                <img src="<%= displayImg %>" class="cart-item-img border" 
                                                     onerror="this.src='https://via.placeholder.com/80?text=S%E1%BA%A3n+Ph%E1%BA%A9m'">
                                            </div>
                                            <div class="col-md-5 col-9">
                                                <h6 class="mb-1 font-weight-bold text-dark">
                                                    <%= item.productId ? item.productId.name : 'Sản phẩm không còn tồn tại' %>
                                                </h6>
                                                <p class="mb-0 text-muted small font-italic">Đơn giá: <%= (item.price || 0).toLocaleString('vi-VN') %>đ</p>
                                            </div>
                                            <div class="col-md-3 col-6 mt-3 mt-md-0 text-center">
                                                <div class="quantity-control p-1">
                                                    <button onclick="updateQuantity('<%= item.productId._id %>', -1)">-</button>
                                                    <input type="text" class="quantity-input" value="<%= item.quantity %>">
                                                    <button onclick="updateQuantity('<%= item.productId._id %>', 1)">+</button>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-6 text-right mt-3 mt-md-0">
                                                <span class="text-danger font-weight-bold h6 mb-0">
                                                    <%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ
                                                </span>
                                            </div>
                                        </div>
                                    </li>
                                <% }) %>
                            </ul>
                        </div>
                    </div>
                    <a href="/customer/home" class="btn btn-link text-primary mt-3 p-0">
                        <i class="fas fa-arrow-left mr-1"></i> Tiếp tục mua sắm
                    </a>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 p-4 rounded-lg bg-white sticky-top" style="top: 20px;">
                        <h5 class="mb-4 border-bottom pb-3 font-weight-bold text-dark">Tóm tắt đơn hàng</h5>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tạm tính:</span>
                            <% const subtotal = cart.items.reduce((t, i) => t + (i.price * i.quantity), 0); %>
                            <span class="font-weight-bold"><%= subtotal.toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="text-muted">Phí vận chuyển:</span>
                            <span class="text-success font-weight-bold">Miễn phí</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4 h4 font-weight-bold">
                            <span>Tổng cộng:</span>
                            <span class="text-orange"><%= subtotal.toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <button onclick="processCheckout()" class="btn btn-block btn-checkout shadow-sm py-3">
                            <i class="fas fa-shopping-bag mr-2"></i>THANH TOÁN NGAY
                        </button>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="card shadow-sm border-0 rounded-lg py-5 text-center bg-white">
                <div class="card-body">
                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329960.png" style="width: 140px; opacity: 0.6;" class="mb-4">
                    <h4 class="text-muted">Giỏ hàng của bạn đang trống!</h4>
                    <p class="text-muted mb-4">Dường như bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
                    <a href="/customer/home" class="btn btn-primary btn-lg px-5 shadow-sm" style="border-radius: 10px;">
                        Khám phá sản phẩm
                    </a>
                </div>
            </div>
        <% } %>
    </div>

<script>
    // Hàm cập nhật số lượng (Tăng/Giảm)
    async function updateQuantity(productId, change) {
        try {
            const response = await fetch('/customer/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, change })
            });
            const result = await response.json();
            
            if (result.success) {
                location.reload(); // Reload để tính toán lại toàn bộ giao diện
            } else {
                alert(result.message); // Hiển thị lỗi tồn kho hoặc lỗi hệ thống
            }
        } catch (error) {
            console.error("Lỗi cập nhật số lượng:", error);
            alert("Không thể cập nhật số lượng lúc này.");
        }
    }

    // Hàm thực hiện đặt hàng (Checkout)
    async function processCheckout() {
        if (!confirm("Bạn có chắc chắn muốn đặt hàng không?")) return;

        const btn = document.querySelector('.btn-checkout');
        const originalText = btn.innerHTML;
        
        // Disable nút để tránh nhấn nhiều lần
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> ĐANG XỬ LÝ...';

        try {
            const response = await fetch('/customer/cart/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });

            const result = await response.json();

            if (result.success) {
                alert("✅ Đặt hàng thành công! Cảm ơn bạn đã mua sắm.");
                window.location.href = '/customer/orders'; 
            } else {
                alert("❌ Lỗi: " + result.message);
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        } catch (error) {
            console.error(error);
            alert("❌ Lỗi kết nối máy chủ. Vui lòng thử lại sau.");
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    }
</script>
</body>
</html>