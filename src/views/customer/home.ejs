<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>Sàn Thương Mại - SaleSphere</title>
    <style>
        :root { --primary-orange: #e44d26; --success-green: #28a745; }
        .product-card { transition: all 0.3s ease; border: none; border-radius: 15px; overflow: hidden; background: #fff; }
        .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.12) !important; }
        .card-img-top { height: 220px; object-fit: cover; background-color: #f8f9fa; transition: transform 0.5s; }
        .product-card:hover .card-img-top { transform: scale(1.05); }
        .badge-category { position: absolute; top: 12px; right: 12px; z-index: 10; background: rgba(23, 162, 184, 0.9); backdrop-filter: blur(4px); }
        .price-text { color: var(--primary-orange); font-size: 1.25rem; letter-spacing: -0.5px; }
        .btn-buy { border-radius: 10px; padding: 10px; font-weight: 700; text-transform: uppercase; font-size: 0.85rem; }
        .cart-badge { top: -5px; right: -10px; font-size: 0.7rem; }
        /* CSS cho nút Đơn hàng mới */
        .order-link { color: #fff !important; font-weight: 500; transition: 0.3s; }
        .order-link:hover { color: #ffc107 !important; text-decoration: none; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand font-weight-bold" href="/customer/home">
                <i class="fas fa-shopping-bag mr-2 text-warning"></i>SaleSphere
            </a>
            <div class="ml-auto d-flex align-items-center">
                <% if (customer) { %>
                <a href="/customer/orders" class="btn btn-link order-link mr-3 d-flex align-items-center">
                    <i class="fas fa-clipboard-list fa-lg mr-1"></i>
                    <span class="d-none d-md-inline">Đơn hàng</span>
                </a>
                <% } %>

                <a href="/customer/cart" class="btn btn-link text-white mr-3 position-relative">
                    <i class="fas fa-shopping-cart fa-lg"></i>
                    <span id="cart-count" class="badge badge-danger badge-pill position-absolute cart-badge">0</span>
                </a>

                <% if (customer) { %>
                    <span class="text-white mr-3 d-none d-md-inline"><i class="fas fa-user-circle mr-1"></i> <strong><%= customer.name %></strong></span>
                    <a href="/customer/logout" class="btn btn-sm btn-outline-danger border-0">Đăng xuất</a>
                <% } else { %>
                    <a href="/customer/login" class="btn btn-sm btn-primary px-4 shadow-sm">Đăng nhập</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 bg-white p-3 rounded-lg shadow-sm">
            <h4 class="mb-3 mb-md-0 text-dark font-weight-bold">Khám phá sản phẩm</h4>
            <div class="d-flex align-items-center">
                <i class="fas fa-filter mr-2 text-muted"></i>
                <select class="form-control border-0 bg-light" style="width: 200px; border-radius: 8px;" 
                        onchange="window.location.href='/customer/home?category=' + encodeURIComponent(this.value)">
                    <option value="Tất cả" <%= (typeof selectedCategory !== 'undefined' && selectedCategory === 'Tất cả') ? 'selected' : '' %>>Tất cả danh mục</option>
                    <% const cats = ['Điện tử', 'Thời trang', 'Thực phẩm', 'Khác'] %>
                    <% cats.forEach(c => { %>
                        <option value="<%= c %>" <%= (typeof selectedCategory !== 'undefined' && selectedCategory === c) ? 'selected' : '' %>><%= c %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <div class="row">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card h-100 shadow-sm product-card">
                            <span class="badge badge-pill badge-info badge-category px-3 py-2 shadow-sm">
                                <%= product.category %>
                            </span>
                            
                            <% 
                                let imgUrl = '/images/no-image.png'; 
                                if (product.image && typeof product.image === 'string') {
                                    imgUrl = product.image;
                                } else if (product.images && product.images.length > 0) {
                                    imgUrl = product.images[0];
                                }
                                if (imgUrl && !imgUrl.startsWith('http') && !imgUrl.startsWith('/')) {
                                    imgUrl = '/' + imgUrl;
                                }
                            %>
                            
                            <div class="overflow-hidden bg-light" style="height: 220px;">
                                <img src="<%= imgUrl %>" class="card-img-top" alt="<%= product.name %>"
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     onerror="this.onerror=null; this.src='https://via.placeholder.com/300x220?text=Lỗi+Ảnh';">
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title text-dark font-weight-bold mb-2 text-truncate" title="<%= product.name %>">
                                    <%= product.name %>
                                </h6>
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="price-text font-weight-bold">
                                            <%= (product.price || 0).toLocaleString('vi-VN') %>đ
                                        </span>
                                        <small class="text-muted"><i class="fas fa-box mr-1"></i><%= product.stock %></small>
                                    </div>
                                    
                                    <div class="btn-group w-100">
                                        <button onclick="addToCart('<%= product._id %>', '<%= product.tenantId %>', '<%= product.price %>')" 
                                                class="btn btn-outline-success shadow-sm" title="Thêm vào giỏ">
                                            <i class="fas fa-cart-plus"></i>
                                        </button>
                                        <button onclick="handleBuyNowDirectly('<%= product._id %>', '<%= product.tenantId %>', '<%= product.price %>')" 
                                                class="btn btn-success shadow-sm font-weight-bold flex-grow-1">
                                            Mua ngay
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 bg-white rounded-lg shadow-sm">
                    <i class="fas fa-search-minus fa-3x text-muted mb-3"></i>
                    <p class="text-muted font-italic">Không tìm thấy sản phẩm nào phù hợp.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
    const isLoggedIn = <%- JSON.stringify(customer ? true : false) %>;

    // 1. Thêm vào giỏ hàng
    async function addToCart(productId, tenantId, price) {
        if (!isLoggedIn) {
            alert("Vui lòng đăng nhập để thêm vào giỏ hàng!");
            window.location.href = '/customer/login';
            return;
        }

        try {
            const res = await fetch('/customer/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, tenantId, price: Number(price) })
            });
            const data = await res.json();
            if (data.success) {
                alert("🛒 " + data.message);
                const badge = document.getElementById('cart-count');
                badge.innerText = Number(badge.innerText) + 1;
            } else {
                alert("❌ Lỗi: " + data.message);
            }
        } catch (e) {
            alert("⚠️ Lỗi kết nối!");
        }
    }

    // 2. Mua Ngay và chuyển hướng xem đơn hàng
    async function handleBuyNowDirectly(productId, tenantId, price) {
        if (!isLoggedIn) {
            alert("Vui lòng đăng nhập để thực hiện mua sắm!");
            window.location.href = '/customer/login';
            return;
        }
        
        if (!confirm("Xác nhận đặt mua sản phẩm này ngay?")) return;

        try {
            // Bước 1: Thêm vào giỏ hàng trước
            const addRes = await fetch('/customer/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, tenantId, price: Number(price), quantity: 1 })
            });
            
            // Bước 2: Gọi API checkout để tạo đơn hàng luôn
            const checkRes = await fetch('/customer/cart/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const data = await checkRes.json();
            if (data.success) {
                alert("✨ Đặt hàng thành công!");
                window.location.href = '/customer/orders'; // Chuyển thẳng tới trang lịch sử
            } else {
                alert("❌ Lỗi thanh toán: " + data.message);
            }
        } catch (e) {
            alert("⚠️ Lỗi hệ thống khi mua hàng!");
        }
    }
    </script>
</body>
</html>