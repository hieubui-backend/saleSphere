<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Đăng nhập | SaleSphere</title>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-lg">
        <div class="text-center mb-8">
            <h1 class="text-4xl font-extrabold text-orange-600">SaleSphere</h1>
            <p class="text-slate-500 mt-2 font-medium">Đăng nhập để bắt đầu mua sắm</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow-sm">
                <p class="text-sm font-bold">Lỗi:</p>
                <p class="text-xs"><%= error %></p>
            </div>
        <% } %>

        <form action="/customer/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Email</label>
                <input type="email" name="email" placeholder="email@example.com" 
                    class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition" required>
            </div>
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1">Mật khẩu</label>
                <input type="password" name="password" placeholder="••••••••" 
                    class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition" required>
            </div>

            <div class="flex items-center justify-between text-xs text-slate-500">
                <label class="flex items-center">
                    <input type="checkbox" class="mr-1 accent-orange-500"> Ghi nhớ đăng nhập
                </label>
                <a href="#" class="hover:text-orange-600">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 rounded-lg shadow-md hover:shadow-lg transform active:scale-[0.98] transition-all">
                ĐĂNG NHẬP
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-slate-100 text-center">
            <p class="text-sm text-slate-600">
                Mới biết đến SaleSphere? 
                <a href="/customer/register" class="text-orange-600 font-bold hover:underline">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</body>
</html>