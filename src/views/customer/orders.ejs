<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>Đơn hàng của tôi - SaleSphere</title>
    <style>
        :root {
            --primary-color: #4a90e2;
            --refund-color: #e83e8c;
        }
        .status-pending { color: #ffc107; font-weight: bold; }
        .status-processing { color: #6f42c1; font-weight: bold; }
        .status-shipping { color: #17a2b8; font-weight: bold; }
        .status-completed { color: #28a745; font-weight: bold; }
        .status-cancelled { color: #dc3545; font-weight: bold; }
        .status-returned { color: #fd7e14; font-weight: bold; }
        
        .status-refund-success { 
            color: #ffffff; 
            background-color: var(--refund-color); 
            padding: 4px 14px; 
            border-radius: 20px; 
            font-size: 0.85rem;
            display: inline-block;
            box-shadow: 0 2px 5px rgba(232, 62, 140, 0.3);
            font-weight: bold;
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .order-card { border-radius: 15px; transition: 0.3s; border: none; overflow: hidden; }
        .order-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important; }
        .btn-dispute { font-size: 0.8rem; padding: 4px 15px; border-radius: 15px; font-weight: 500; }
        .navbar-brand { letter-spacing: 1px; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand font-weight-bold" href="/customer/home">SALESPHERE</a>
            <div class="ml-auto text-white">
                <i class="fas fa-user-circle mr-1"></i> <%= customer.name %>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-history mr-2 text-primary"></i>Lịch sử đơn hàng</h2>
            <div class="text-right">
                <small class="text-muted d-block">Trạng thái: <strong>Trực tuyến</strong></small>
                <i class="fas fa-circle text-success" style="font-size: 8px;"></i>
            </div>
        </div>

        <% if (orders && orders.length > 0) { %>
            <div id="orderList">
                <% orders.forEach(order => { %>
                    <div class="card mb-4 order-card shadow-sm" id="order-<%= order._id %>">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted">Mã đơn: <strong class="text-dark">#<%= order._id.toString().slice(-8).toUpperCase() %></strong></span>
                            <div class="d-flex align-items-center">
                                <span class="status-container mr-3" id="status-<%= order._id %>">
                                    <%# --- LOGIC PHÂN TẦNG TRẠNG THÁI --- %>
                                    <% if (order.status === 'returned') { %>
                                        <span class="status-refund-success"><i class="fas fa-hand-holding-usd"></i> Đã hoàn tiền</span>
                                    <% } else if (order.dispute && order.dispute.isDisputed && order.dispute.status === 'pending') { %>
                                        <span class="status-returned"><i class="fas fa-exclamation-circle"></i> Đang khiếu nại</span>
                                    <% } else if (order.status === 'pending') { %>
                                        <span class="status-pending"><i class="fas fa-clock"></i> Chờ xác nhận</span>
                                    <% } else if (order.status === 'processing') { %>
                                        <span class="status-processing"><i class="fas fa-box"></i> Đang chuẩn bị</span>
                                    <% } else if (order.status === 'shipping') { %>
                                        <span class="status-shipping"><i class="fas fa-shipping-fast"></i> Đang giao hàng</span>
                                    <% } else if (order.status === 'completed') { %>
                                        <span class="status-completed"><i class="fas fa-check-circle"></i> Đã hoàn thành</span>
                                    <% } else { %>
                                        <span class="status-cancelled"><i class="fas fa-ban"></i> Đã hủy đơn</span>
                                    <% } %>
                                </span>
                                
                                <%# Nút khiếu nại chỉ hiện khi đơn hoàn thành và chưa từng khiếu nại %>
                                <% if(order.status === 'completed' && (!order.dispute || !order.dispute.isDisputed)) { %>
                                    <button class="btn btn-outline-danger btn-dispute" onclick="openDisputeModal('<%= order._id %>')">
                                        Khiếu nại / Hoàn tiền
                                    </button>
                                <% } %>
                            </div>
                        </div>

                        <div class="card-body py-4">
                            <% order.items.forEach(item => { %>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light p-2 rounded mr-3">
                                            <i class="fas fa-shopping-bag text-secondary"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 font-weight-bold"><%= item.name %></h6>
                                            <small class="text-muted">Đơn giá: <%= item.price.toLocaleString('vi-VN') %>đ</small>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <span class="badge badge-pill badge-light border">x<%= item.quantity %></span>
                                        <p class="mb-0 font-weight-bold mt-1"><%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ</p>
                                    </div>
                                </div>
                            <% }) %>
                            <hr class="my-4">
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <p class="text-muted small mb-1"><i class="far fa-calendar-alt mr-1"></i> Ngày mua: <%= new Date(order.createdAt).toLocaleString('vi-VN') %></p>
                                    <p class="text-muted small mb-0"><i class="fas fa-map-marker-alt mr-1"></i> Giao đến: Địa chỉ của khách hàng</p>
                                </div>
                                <div class="text-right">
                                    <span class="text-muted small">Thành tiền:</span>
                                    <h4 class="text-danger font-weight-bold mb-0"><%= order.totalAmount.toLocaleString('vi-VN') %>đ</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="card border-0 shadow-sm py-5 text-center order-card">
                <div class="card-body">
                    <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" alt="No orders" style="width: 120px; opacity: 0.5;">
                    <h5 class="mt-4 text-muted">Bạn chưa có đơn hàng nào</h5>
                    <a href="/customer/home" class="btn btn-primary mt-3 px-4 shadow-sm">Mua sắm ngay</a>
                </div>
            </div>
        <% } %>
    </div>

    <div class="modal fade" id="disputeModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg" style="border-radius: 20px; border: none;">
                <div class="modal-header border-0 bg-danger text-white py-4" style="border-radius: 20px 20px 0 0;">
                    <h5 class="modal-title font-weight-bold"><i class="fas fa-shield-alt mr-2"></i>Yêu cầu hoàn trả & Hoàn tiền</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <form id="disputeForm">
                    <div class="modal-body p-4">
                        <input type="hidden" id="disputeOrderId">
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-dark">Lý do khiếu nại <span class="text-danger">*</span></label>
                            <select class="form-control form-control-lg border-0 bg-light" id="disputeReason" required style="border-radius: 12px; font-size: 0.95rem;">
                                <option value="">Chọn lý do hoàn trả...</option>
                                <option value="Sản phẩm bị lỗi/Hư hỏng">Sản phẩm bị lỗi / Hư hỏng vật lý</option>
                                <option value="Giao sai sản phẩm">Giao sai mẫu mã / màu sắc / kích thước</option>
                                <option value="Thiếu sản phẩm">Đơn hàng bị thiếu sản phẩm</option>
                                <option value="Khác">Lý do khác</option>
                            </select>
                        </div>
                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-dark">Mô tả chi tiết</label>
                            <textarea class="form-control border-0 bg-light" id="disputeDesc" rows="4" style="border-radius: 12px;" placeholder="Vui lòng cung cấp thêm thông tin..."></textarea>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold text-dark">Hình ảnh bằng chứng (Link)</label>
                            <input type="text" class="form-control border-0 bg-light" id="disputeImage" style="border-radius: 12px;" placeholder="Dán link ảnh tại đây">
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4">
                        <button type="button" class="btn btn-light px-4" data-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" id="btnSubmitDispute" class="btn btn-danger px-5 font-weight-bold shadow-sm">Gửi yêu cầu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>
    
    <script>
        const socket = io();

        function openDisputeModal(orderId) {
            $('#disputeOrderId').val(orderId);
            $('#disputeModal').modal('show');
        }

        $('#disputeForm').submit(async function(e) {
            e.preventDefault();
            const orderId = $('#disputeOrderId').val();
            const submitBtn = $('#btnSubmitDispute');
            
            const data = {
                reason: $('#disputeReason').val(),
                description: $('#disputeDesc').val(),
                images: $('#disputeImage').val().trim() ? [$('#disputeImage').val().trim()] : []
            };

            submitBtn.prop('disabled', true).html('<i class="fas fa-circle-notch fa-spin mr-2"></i>Đang xử lý...');

            try {
                const res = await fetch(`/customer/orders/${orderId}/dispute`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();
                if (result.success) {
                    $('#disputeModal').modal('hide');
                    Swal.fire({ 
                        icon: 'success', 
                        title: 'Đã gửi khiếu nại!', 
                        text: 'Vui lòng chờ Admin xác nhận.',
                        confirmButtonColor: '#28a745'
                    }).then(() => location.reload());
                } else {
                    throw new Error(result.message);
                }
            } catch (err) {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: err.message });
            } finally {
                submitBtn.prop('disabled', false).text('Gửi yêu cầu');
            }
        });

        // Xử lý Socket.io Real-time
        socket.on('orderUpdate', function(data) {
            const statusContainer = document.querySelector(`#status-${data.orderId}`);
            if (statusContainer) {
                let html = '';
                
                // Đồng bộ logic hiển thị với Server
                if (data.status === 'returned') {
                    html = `<span class="status-refund-success"><i class="fas fa-hand-holding-usd"></i> Đã hoàn tiền</span>`;
                } else if (data.isDisputed && data.disputeStatus === 'pending') {
                    html = `<span class="status-returned"><i class="fas fa-exclamation-circle"></i> Đang khiếu nại</span>`;
                } else {
                    const statusMap = {
                        'pending': { class: 'status-pending', icon: 'fa-clock', text: 'Chờ xác nhận' },
                        'processing': { class: 'status-processing', icon: 'fa-box', text: 'Đang chuẩn bị' },
                        'shipping': { class: 'status-shipping', icon: 'fa-shipping-fast', text: 'Đang giao hàng' },
                        'completed': { class: 'status-completed', icon: 'fa-check-circle', text: 'Đã hoàn thành' },
                        'cancelled': { class: 'status-cancelled', icon: 'fa-ban', text: 'Đã hủy đơn' }
                    };
                    const s = statusMap[data.status];
                    if (s) html = `<span class="${s.class}"><i class="fas ${s.icon}"></i> ${s.text}</span>`;
                }

                if (html) {
                    statusContainer.innerHTML = html;
                    
                    // Xử lý nút khiếu nại
                    const btnDispute = document.querySelector(`#order-${data.orderId} .btn-dispute`);
                    if (btnDispute && (data.status === 'returned' || data.isDisputed)) {
                        btnDispute.remove();
                    }
                }

                Swal.fire({
                    toast: true, position: 'top-end', icon: 'info',
                    title: `Đơn hàng #${data.orderId.slice(-6).toUpperCase()} cập nhật trạng thái mới.`,
                    showConfirmButton: false, timer: 4000
                });
            }
        });
    </script>
</body>
</html>