<div class="mb-8 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Quản lý người mua toàn sàn</h1>
        <p class="text-slate-500 text-sm">Danh sách tất cả khách hàng đăng ký trên hệ thống SaleSphere</p>
    </div>
</div>

<!-- Form thêm người mua -->
<form id="addCustomerForm" class="mb-4 flex gap-2 items-center">
    <input type="text" name="name" placeholder="Họ tên" required class="border rounded px-2 py-1" />
    <input type="email" name="email" placeholder="Email" required class="border rounded px-2 py-1" />
    <input type="text" name="phone" placeholder="Số điện thoại" class="border rounded px-2 py-1" />
    <input type="text" name="address" placeholder="Địa chỉ" class="border rounded px-2 py-1" />
    <button type="submit" class="bg-blue-600 text-white px-4 py-1 rounded">Thêm người mua</button>
</form>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                <tr>
                    <th class="px-6 py-4">Họ tên</th>
                    <th class="px-6 py-4">Email</th>
                    <th class="px-6 py-4">Số điện thoại</th>
                    <th class="px-6 py-4">Phân loại</th>
                    <th class="px-6 py-4">Ngày đăng ký</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (typeof customers !== 'undefined' && customers.length > 0) { %>
                    <% customers.forEach(item => { %> 
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 font-bold text-slate-700">
                            <span id="name-<%= item._id %>"><%= item.name %></span>
                            <input type="text" id="edit-name-<%= item._id %>" value="<%= item.name %>" class="hidden border rounded px-2 py-1" />
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">
                            <span id="email-<%= item._id %>"><%= item.email %></span>
                            <input type="email" id="edit-email-<%= item._id %>" value="<%= item.email %>" class="hidden border rounded px-2 py-1" />
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-500">
                            <span id="phone-<%= item._id %>"><%= item.phone || 'N/A' %></span>
                            <input type="text" id="edit-phone-<%= item._id %>" value="<%= item.phone %>" class="hidden border rounded px-2 py-1" />
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 bg-green-100 text-green-700 rounded-full text-[10px] font-bold uppercase">KHÁCH HÀNG HỆ THỐNG</span>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-500">
                            <%= new Date(item.createdAt).toLocaleDateString('vi-VN') %>
                        </td>
                        <td class="px-6 py-4 flex gap-2">
                            <button class="bg-yellow-400 text-white px-2 py-1 rounded" onclick="showEdit('<%= item._id %>')">Sửa</button>
                            <button class="bg-red-600 text-white px-2 py-1 rounded" onclick="deleteCustomer('<%= item._id %>')">Xóa</button>
                            <button class="bg-green-600 text-white px-2 py-1 rounded hidden" id="save-<%= item._id %>" onclick="saveEdit('<%= item._id %>')">Lưu</button>
                            <button class="bg-gray-400 text-white px-2 py-1 rounded hidden" id="cancel-<%= item._id %>" onclick="cancelEdit('<%= item._id %>')">Hủy</button>
                        </td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-slate-400 italic">
                            Chưa có khách hàng nào trên hệ thống
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
    <script>
    // Thêm người mua
    document.getElementById('addCustomerForm').onsubmit = async function(e) {
        e.preventDefault();
        const form = e.target;
        const data = {
            name: form.name.value,
            email: form.email.value,
            phone: form.phone.value,
            address: form.address.value
        };
        const res = await fetch('/customer/admin/customers', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) location.reload();
        else alert(result.message);
    };

    // Xóa người mua
    async function deleteCustomer(id) {
        if (!confirm('Bạn có chắc muốn xóa người mua này?')) return;
        const res = await fetch(`/customer/admin/customers/${id}`, { method: 'DELETE' });
        const result = await res.json();
        if (result.success) location.reload();
        else alert(result.message);
    }

    // Hiện form sửa
    function showEdit(id) {
        document.getElementById(`name-${id}`).style.display = 'none';
        document.getElementById(`email-${id}`).style.display = 'none';
        document.getElementById(`phone-${id}`).style.display = 'none';
        document.getElementById(`edit-name-${id}`).classList.remove('hidden');
        document.getElementById(`edit-email-${id}`).classList.remove('hidden');
        document.getElementById(`edit-phone-${id}`).classList.remove('hidden');
        document.getElementById(`save-${id}`).classList.remove('hidden');
        document.getElementById(`cancel-${id}`).classList.remove('hidden');
    }
    function cancelEdit(id) {
        document.getElementById(`name-${id}`).style.display = '';
        document.getElementById(`email-${id}`).style.display = '';
        document.getElementById(`phone-${id}`).style.display = '';
        document.getElementById(`edit-name-${id}`).classList.add('hidden');
        document.getElementById(`edit-email-${id}`).classList.add('hidden');
        document.getElementById(`edit-phone-${id}`).classList.add('hidden');
        document.getElementById(`save-${id}`).classList.add('hidden');
        document.getElementById(`cancel-${id}`).classList.add('hidden');
    }
    async function saveEdit(id) {
        const name = document.getElementById(`edit-name-${id}`).value;
        const email = document.getElementById(`edit-email-${id}`).value;
        const phone = document.getElementById(`edit-phone-${id}`).value;
        const res = await fetch(`/customer/admin/customers/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, phone })
        });
        const result = await res.json();
        if (result.success) location.reload();
        else alert(result.message);
    }
    </script>