<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Quản lý đơn hàng toàn sàn</h1>
    <p class="text-slate-500 text-sm">Xem và kiểm soát mọi giao dịch trên hệ thống</p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-widest">
                <tr>
                    <th class="px-6 py-4">Mã đơn</th>
                    <th class="px-6 py-4">Cửa hàng</th>
                    <th class="px-6 py-4">Khách hàng</th>
                    <th class="px-6 py-4">Tổng tiền</th>
                    <th class="px-6 py-4">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% orders.forEach(order => { %>
                <tr class="hover:bg-slate-50/50">
                    <td class="px-6 py-4 font-mono text-xs text-indigo-600 font-bold">#<%= order._id.toString().substring(18).toUpperCase() %></td>
                    <td class="px-6 py-4 font-medium text-slate-700"><%= order.tenantId?.name || 'N/A' %></td>
                    <td class="px-6 py-4 text-sm"><%= order.shippingAddress?.fullname %></td>
                    <td class="px-6 py-4 font-bold"><%= order.totalAmount.toLocaleString('vi-VN') %>₫</td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase status-<%= order.status %>">
                            <%= order.status %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>