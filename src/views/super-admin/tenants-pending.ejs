<div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-800">Cửa hàng chờ phê duyệt</h1>
    <p class="text-slate-500 text-sm">Danh sách các đối tác mới đăng ký cần xác thực để hoạt động</p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-500 text-xs font-bold uppercase">
                <tr>
                    <th class="px-6 py-4">Tên Cửa hàng</th>
                    <th class="px-6 py-4">Email liên hệ</th>
                    <th class="px-6 py-4">Ngày đăng ký</th>
                    <th class="px-6 py-4 text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (tenants && tenants.length > 0) { %>
                    <% tenants.forEach(tenant => { %>
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-bold text-slate-700"><%= tenant.name %></div>
                                <div class="text-xs text-indigo-600">/<%= tenant.slug %></div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600"><%= tenant.email %></td>
                            <td class="px-6 py-4 text-sm text-slate-500">
                                <%= new Date(tenant.createdAt).toLocaleDateString('vi-VN') %>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-3">
                                    <a href="/super-admin/tenants/approve/<%= tenant._id %>" 
                                       class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-lg text-xs font-bold transition-all"
                                       onclick="return confirm('Xác nhận phê duyệt cho cửa hàng [<%= tenant.name %>] hoạt động?')">
                                        Phê duyệt ngay
                                    </a>
                                    <a href="/super-admin/tenants/toggle/<%= tenant._id %>" 
                                       class="text-slate-400 hover:text-red-600 text-xs font-medium transition-all">
                                        Từ chối
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-slate-400">
                            Không có yêu cầu nào đang chờ xử lý.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>