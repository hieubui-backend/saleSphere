<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salesphere Admin | <%= typeof title !== 'undefined' ? title : 'Quản lý' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        aside::-webkit-scrollbar { width: 4px; }
        aside::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
        .nav-item-active {
            background-color: #4f46e5 !important;
            color: white !important;
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.4);
        }
    </style>
</head>
<body class="bg-slate-50 flex">

    <aside class="w-64 bg-slate-900 min-h-screen text-slate-300 flex flex-col shadow-xl sticky top-0 h-screen z-50">
        <div class="p-6">
            <div class="flex items-center gap-3 text-white">
                <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center shadow-lg shadow-indigo-500/50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                </div>
                <span class="text-xl font-bold tracking-tight">Salesphere</span>
            </div>
        </div>

        <nav class="flex-1 px-4 space-y-1 mt-4 overflow-y-auto">
            <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Chính</p>
            
            <% 
                let dashboardLink = (typeof user !== 'undefined' && user.role === 'super_admin') ? "/super-admin/dashboard" : "/admin/dashboard";
                
                // Hàm kiểm tra active linh hoạt hơn
                const checkActive = (targets) => {
                    const currentTitle = typeof title !== 'undefined' ? title : '';
                    return targets.includes(currentTitle) ? 'nav-item-active' : 'hover:bg-slate-800 hover:text-white';
                };
            %>

            <a href="<%= dashboardLink %>" 
               class="flex items-center gap-3 py-3 px-4 rounded-xl transition-all group <%= checkActive(['Báo cáo hệ thống', 'Báo cáo tổng quan', 'Hệ thống Quản trị SaleSphere', 'Báo cáo cửa hàng']) %>">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
                <span class="font-medium text-sm">Dashboard</span>
            </a>

            <% if (typeof user !== 'undefined' && user.role === 'super_admin') { %>
                <div class="pt-6 mb-2">
                    <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Quản trị sàn</p>
                    
                    <a href="/super-admin/tenants" 
                       class="flex items-center gap-3 py-3 px-4 rounded-xl transition-all group <%= checkActive(['Quản lý danh sách cửa hàng', 'Quản lý cửa hàng']) %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                        <span class="font-medium text-sm">Quản lý Cửa hàng</span>
                    </a>

                    <a href="/super-admin/customers" 
                       class="flex items-center gap-3 py-3 px-4 rounded-xl transition-all group <%= checkActive(['Quản lý khách hàng toàn sàn', 'Quản lý người mua toàn sàn']) %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 01-9-3.374M16 3.13a4 4 0 111.5 7.63L16 3.13z" />
                        </svg>
                        <span class="font-medium text-sm">Quản lý Người mua</span>
                    </a>
                </div>
            <% } %>

            <% if (typeof user !== 'undefined' && (user.role === 'admin' || user.role === 'vendor' || user.role === 'staff')) { %>
                <div class="pt-6 mb-2">
                    <p class="px-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Cửa hàng của bạn</p>
                    <a href="/admin/products" class="flex items-center gap-3 py-3 px-4 rounded-xl transition-all group <%= checkActive(['Quản lý sản phẩm']) %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        <span class="font-medium text-sm">Sản phẩm</span>
                    </a>
                    <a href="/admin/orders" class="flex items-center gap-3 py-3 px-4 rounded-xl transition-all group <%= checkActive(['Quản lý đơn hàng']) %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        <span class="font-medium text-sm">Đơn hàng</span>
                    </a>
                </div>
            <% } %>
        </nav>

        <div class="p-4 border-t border-slate-800">
            <a href="/admin/logout" class="flex items-center gap-3 py-3 px-4 rounded-xl text-red-400 hover:bg-red-500/10 transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span class="font-medium text-sm">Đăng xuất</span>
            </a>
        </div>
    </aside>

    <main class="flex-1 min-h-screen flex flex-col overflow-hidden">
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 shadow-sm sticky top-0 z-40">
            <div class="flex items-center gap-2 text-sm font-medium text-slate-500">
                <span>Chào mừng,</span>
                <span class="text-slate-900 font-bold"><%= typeof user !== 'undefined' ? user.name : 'Quản trị viên' %></span>
                <span class="mx-2 text-slate-300">|</span>
                <span class="text-indigo-600 font-semibold px-2 py-1 bg-indigo-50 rounded text-[10px] uppercase tracking-wider shadow-sm border border-indigo-100">
                    <%= typeof user !== 'undefined' ? user.role.replace('_', ' ') : 'N/A' %>
                </span>
            </div>
            
            <div class="flex items-center gap-4">
                <% if (typeof user !== 'undefined' && user.role === 'super_admin') { %>
                    <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-[10px] font-extrabold ring-1 ring-amber-200 uppercase tracking-wider">
                        HỆ THỐNG TRUNG TÂM
                    </span>
                <% } else if (typeof user !== 'undefined' && user.tenantId) { %>
                    <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-[10px] font-extrabold ring-1 ring-slate-200 uppercase tracking-wider">
                        SHOP ID: <%= user.tenantId %>
                    </span>
                <% } %>
            </div>
        </header>

        <div class="p-8 overflow-y-auto flex-1">
            <%- body %>
        </div>
    </main>

</body>
</html>