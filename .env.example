# ════════════════════════════════════════
# SaleSphere Backend – Environment Template
# Copy file này thành .env và điền giá trị thật
# cp .env.example .env
# ════════════════════════════════════════

# ── App ──────────────────────────────────
NODE_ENV=production
PORT=5000
CORS_ORIGIN=http://your-vps-ip-or-domain

# ── MongoDB ──────────────────────────────
# Option 1: Dùng MongoDB trong Docker (khuyến nghị cho VPS)
MONGO_URI=mongodb://admin:salesphere_secret@mongodb:27017/salesphere_db?authSource=admin

# Option 2: Dùng MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/salesphere_db

# Credentials cho MongoDB container (dùng cùng với docker-compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=salesphere_secret

# ── Redis ────────────────────────────────
REDIS_URL=redis://:redis_secret@redis:6379
REDIS_PASSWORD=redis_secret

# ── JWT ──────────────────────────────────
JWT_SECRET=your_super_secret_key_here_minimum_32_chars
JWT_EXPIRES_IN=1d
SESSION_SECRET=your_session_secret_here

# ── PayOS ────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ── Email (SMTP) ─────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS="SaleSphere <noreply@salesphere.com>"
